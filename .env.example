POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=podcast_summarizer

# Required for Security: Generate a strong secret (e.g., openssl rand -hex 32)
SECRET_KEY=your_development_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200
LOG_LEVEL=INFO
LOG_JSON=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_STORAGE_URL=redis://redis:6379/0
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
CACHE_DEFAULT_TTL_SEC=120
CACHE_EPISODE_TTL_SEC=300
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true
DB_SLOW_QUERY_MS=250

# Redis URL for rate limiting and task queue
REDIS_URL=redis://redis:6379/0

# Optional: Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_id_here
SPOTIFY_CLIENT_SECRET=your_secret_here

# Required for Speaker Diarization: Get from https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# LLM routing and resilience
LLM_PROVIDER=ollama
# Ollama model to use (pull it first: docker exec psp-ollama ollama pull mistral)
OLLAMA_MODEL=mistral
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_FALLBACK_CHAIN=ollama:mistral
LLM_REQUEST_TIMEOUT_SEC=120
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_BASE_SEC=0.8
LLM_CIRCUIT_BREAKER_FAILURES=5
LLM_CIRCUIT_BREAKER_COOLDOWN_SEC=60
# Max context window per LLM call; actual num_ctx is auto-sized per request
LLM_NUM_CTX=16384
LLM_CTX_WARN_RATIO=0.9
LLM_AB_TEST_RATIO=50

# Pipeline behavior
# Summary length: tldr (fast, focused) | standard | deep (slow, exhaustive)
SUMMARY_MODE=tldr
# Translate the full transcript into the target language (adds dozens of LLM
# calls per episode; summaries are always generated in the target language)
TRANSLATE_TRANSCRIPT=false
# Fact-checking of extracted claims: none | searxng (requires a SearxNG
# instance with the JSON API enabled, e.g. self-hosted at SEARXNG_URL)
FACT_CHECK_PROVIDER=none
SEARXNG_URL=https://searx.be
